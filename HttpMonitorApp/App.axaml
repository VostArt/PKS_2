<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HttpMonitorApp.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />
        <!-- Обязательно для работы DataGrid -->
